@startuml
title Diskussions-Pipeline — Prompt- & Sprachtheorie-Sicht (ein Turn)

skinparam dpi 110
skinparam defaultFontSize 11
skinparam noteFontSize 10

legend top right
  |<#E8F0FE> Moderator-Call|
  |<#E6F4EA> Agent-Call|
  |<#FFF4E5> Sprachtheorie|
  |<#FFFFFF> System / deterministisch|
endlegend

start
floating note left #FFFFFF
  **system.blade.php** vor jedem LLM-Call:
  akad. Simulation, Personas fiktiv, keine
  KI-Distanzierung, Ausgabeformat wörtlich.
end note

partition "1. Moderator route()" {
  #E8F0FE:**moderator/route.blade.php**
  In: Kontext + Teilnehmer "Name [E7]" + Nachrichten
  + Advisory (agenda_phase, pending_user)
  Out (JSON): candidates[] + Directive
  {role, agenda_step, convergence_intent, address_user};
  note right #FFF4E5
    **Turn-Allocation** (Sacks/Schegloff 1974):
    Floor-Vergabe. Vorrang: offene Nutzerfrage
    > offenes Adjazenzpaar an Experten.
  end note
}

partition "2. Agent think() (parallel)" {
  #E6F4EA:**agent/think.blade.php** je Kandidat
  In: Persona + Kontext + eigenes Gedächtnis + Nachrichten
  Out: GEDÄCHTNIS-UPDATE (persistiert)
  + BEITRAGSABSICHT (1 Satz, nur Auswahlsignal);
  note right #FFF4E5
    **Gedächtnis-Struktur = Theorie:**
    [Token] je Teilnehmer = partner-spez. Modell
    (Clark, Recipient Design); [OFFENE_FRAGEN] =
    konditionelle Relevanz / offene Paare;
    [STAND] = Common Ground.
    Absicht ≠ Äußerung.
  end note
}

partition "3. Moderator select()" {
  if (n > 1 Kandidaten?) then (ja)
    #E8F0FE:**moderator/select.blade.php**
    In: Beitragsabsichten + recent_speakers/-types
    Out (JSON): winner;
    note right #FFF4E5
      Rangfolge: Nutzerfrage > Adjazenzpaar
      > **Kein Back-to-Back** (Sprecherwechsel).
    end note
  else (nein)
    :Pass-through;
  endif
}

partition "4. Agent speak()" {
  #E6F4EA:**agent/speak.blade.php** (Gewinner)
  +BLOCK 4 Reaktions-Typen, +BLOCK 5 Reparatur,
  +Anti-Echo-Einstiege, +Directive
  Out: Turn-Text + ---STEUERUNG--- (ADRESSAT + PAARTYP);
  note right #FFF4E5
    BLOCK 4 = **Präferenzorganisation** (Pomerantz):
    Ablehnung mit Verzögerungssignal + Begründung.
    BLOCK 5 = **Reparatur** (Schegloff 1977):
    Selbst- vor Fremdkorrektur.
    PAARTYP = **Adjazenzpaar-Typ**.
  end note
}

partition "5.–6. System (deterministisch)" {
  :**Persist:** Nachricht + adjacency_partner (Paar materialisiert);
  :**State:** recent_speakers/-types, Agenda-Phase fortschreiben;
}

partition "7. Summarizer (bei Schwelle)" {
  if (unsummierte Nachrichten > Schwelle?) then (ja)
    :**shorten-chat.blade.php** → Chat-Summary
    (neueste N Nachrichten bleiben roh);
    note right #FFF4E5
      Kontextfenster-Management: ältere Turns
      verdichtet, Common Ground bleibt erhalten.
    end note
  else (nein)
    :keine Summary;
  endif
}

stop
@enduml
